# ── Banco de dados ───────────────────────────────
# Docker → DB_HOST=db   |   Local → DB_HOST=127.0.0.1
DB_HOST=db
DB_NAME=replay_dev
DB_USER=replay
DB_PASS=replay_secret

# ── Cloudflare R2 ────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=replays

# ── API key (mesmo valor de REPLAY_BACKEND_API_KEY no edge device)
API_KEY=dev-secret-123

# ── Fuso horário do campo (usado para slots e criação de games)
TZ=America/Sao_Paulo

# ── Mercado Pago ─────────────────────────────────
# Teste: TEST-xxxx  |  Produção: APP_USR-xxxx
MP_ACCESS_TOKEN=
MP_PAYER_EMAIL=pagamento@replay.com.br

# ── Preços ───────────────────────────────────────
PRICE_FULL_GAME=25.00
PRICE_PER_CLIP=5.00
PRICE_MONTHLY_SUBSCRIPTION=59.90
PIX_MOCK=false

# ── Modo gratuito (MVP) ───────────────────────────────
# true = sem paywall, token emitido direto; false = Mercado Pago ativo
FREE_MODE=false

# ── URLs (sem barra final) ────────────────────────
APP_URL=https://seusite.com.br
API_URL=https://api.seusite.com.br
